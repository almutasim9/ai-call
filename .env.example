# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Keep secret — server only

# ─── Meta / Facebook ─────────────────────────────────────────────────────────
# Found in: Meta App Dashboard → App Settings → Basic
META_APP_ID=your_meta_app_id                          # Found in Meta App Dashboard → App Settings → Basic → App ID
META_VERIFY_TOKEN=your_random_verify_token            # Any random string you choose
META_APP_SECRET=your_app_secret_here                  # Used to verify webhook HMAC signatures

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_SECRET=your_strong_admin_secret_here            # Header secret for admin API routes
ADMIN_EMAIL=you@example.com                           # Only this email can access /admin

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Found in: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting Meta access tokens at rest in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: If you change this key, existing tokens become unreadable — re-enter them in Settings.
ENCRYPTION_KEY=your_64_char_hex_key_here
